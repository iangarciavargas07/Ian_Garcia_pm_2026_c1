#include <stdio.h>
#include <stdlib.h>

#define CANTIDAD 5

struct Alumno {
    int matricula;
    char nombre[50];
    float promedio;
};

int main() {

    struct Alumno alumnos[CANTIDAD];
    int i;

    printf("===== REGISTRO DE ALUMNOS =====\n");

    for(i = 0; i < CANTIDAD; i++) {

        printf("\nAlumno %d\n", i + 1);

        printf("Matricula: ");
        scanf("%d", &alumnos[i].matricula);

        getchar();  // Limpia el buffer antes de leer texto

        printf("Nombre: ");
        fgets(alumnos[i].nombre, 50, stdin);

        printf("Promedio: ");
        scanf("%f", &alumnos[i].promedio);
    }

    printf("\n===== LISTA DE ALUMNOS =====\n");

    for(i = 0; i < CANTIDAD; i++) {

        printf("\nAlumno %d\n", i + 1);
        printf("Matricula: %d\n", alumnos[i].matricula);
        printf("Nombre: %s", alumnos[i].nombre);
        printf("Promedio: %.2f\n", alumnos[i].promedio);
    }

    return 0;
}
