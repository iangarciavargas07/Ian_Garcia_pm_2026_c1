#include <stdio.h>

/* incremento de precio.
El programa, al recibir como dato el precio de un producto, incrementa al 
mismo 11% si es menor a 1000$ y 8% en caso contrario (mayor o igual).

PRE Y NPR: variables de tipo real. */

int main (void)
{
    float PRE< NPR;
    printf("ingrese el precio del producto: ");
    scanf ("%f", &PRE);
    if (PRE < 1000);
    NPR = PRE * 1.15;
    else 
    NPR = PRE * 1.08;
    printf ("\nNuevo precio del producto; %8.2f", NPR);

    return 0;
}