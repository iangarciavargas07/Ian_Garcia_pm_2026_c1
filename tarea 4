#include <iostream>
#include <cmath>

using namespace std;

int main() {

    int opcion;
    double num1, num2, resultado;

    cout << "CALCULADORA\n";
    cout << "1. Suma\n";
    cout << "2. Resta\n";
    cout << "3. Multiplicacion\n";
    cout << "4. Division\n";
    cout << "5. Raiz cuadrada\n";
    cout << "Seleccione una opcion: ";
    cin >> opcion;

    if(opcion == 1){
        cout << "Ingrese dos numeros: ";
        cin >> num1 >> num2;
        resultado = num1 + num2;
        cout << "Resultado: " << resultado << endl;
    }

    else if(opcion == 2){
        cout << "Ingrese dos numeros: ";
        cin >> num1 >> num2;
        resultado = num1 - num2;
        cout << "Resultado: " << resultado << endl;
    }

    else if(opcion == 3){
        cout << "Ingrese dos numeros: ";
        cin >> num1 >> num2;
        resultado = num1 * num2;
        cout << "Resultado: " << resultado << endl;
    }

    else if(opcion == 4){
        cout << "Ingrese dos numeros: ";
        cin >> num1 >> num2;

        if(num2 == 0){
            cout << "Error: no se puede dividir entre 0" << endl;
        } 
        else {
            resultado = num1 / num2;
            cout << "Resultado: " << resultado << endl;
        }
    }

    else if(opcion == 5){
        cout << "Ingrese un numero: ";
        cin >> num1;

        if(num1 < 0){
            cout << "Error: no se puede sacar raiz de un numero negativo" << endl;
        }
        else{
            resultado = sqrt(num1);
            cout << "Resultado: " << resultado << endl;
        }
    }

    else{
        cout << "Opcion no valida" << endl;
    }

    return 0;
}
